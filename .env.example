# ============================================================
# CaseHub Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === Organization ===
# Display name shown in the UI, emails, and documents
ORG_NAME=Your Law Firm Name
# Primary contact email for the organization
ORG_EMAIL=info@yourfirm.com
# Organization domain (used for subdomain routing in multi-tenant mode)
ORG_DOMAIN=yourfirm.com
# Secondary/center email (for shared inbox processing)
ORG_CENTER_EMAIL=center@yourfirm.com
# Prefix for case numbers (e.g., "YLF" -> YLF-2026-0001)
CASE_PREFIX=YLF
# Comma-separated team member names (for task assignment dropdowns)
TEAM_MEMBERS=Attorney One,Attorney Two,Paralegal One

# === Product ===
# Which product to run: "immigration" (full white-label) or "lite" (Brazilian law firms)
CASEHUB_PRODUCT=immigration
# Override currency/timezone (auto-set per product if empty)
# DEFAULT_CURRENCY=USD
# DEFAULT_TIMEZONE=America/New_York

# === Internal Services ===
# WhatsApp bot service URL
WHATSAPP_BOT_URL=http://localhost:3001
# LM Studio (local LLM) URL
# LM_STUDIO_URL=http://localhost:1234
# ILC Tools service URL (immigration only)
# ILC_TOOLS_URL=http://localhost:8000

# === Stripe (Subscription & Payments) ===
# Price IDs for paid plans (create in Stripe Dashboard)
# STRIPE_PRICE_PROFESSIONAL=price_xxx
# STRIPE_PRICE_ENTERPRISE=price_xxx

# === Admin (first-run only) ===
# Email for the initial admin account (created on first startup)
ADMIN_EMAIL=admin@yourfirm.com

# === Database ===
# PostgreSQL connection string
DATABASE_URL=postgresql://casehub:CHANGE_ME@localhost/casehub

# === Authentication (REQUIRED) ===
# JWT signing key — MUST be set before starting the app
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# === PII Encryption (REQUIRED) ===
# Fernet key for encrypting SSN, alien_number, passport_number at rest
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose this key, encrypted PII data is unrecoverable!
ENCRYPTION_KEY=
# Session duration in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Cookie name for the auth token (change if running multiple instances)
COOKIE_NAME=casehub_token

# === Server ===
# Public-facing URL (used for links in emails, redirects, etc.)
BASE_URL=https://app.casehub.io
# URL prefix for all routes (e.g., /casehub -> https://domain.com/casehub/dashboard)
PREFIX=/casehub
# Server port (uvicorn binds to this)
PORT=8001
# Host port used by docker-compose.vps-dev.yml on the Oracle dev instance
CASEHUB_DEV_PORT=8004
# Host header used by docker-compose.vps-dev.yml healthcheck on Oracle dev
CASEHUB_DEV_HEALTH_HOST=app.example.com
# Override upload directory (default: ./uploads)
UPLOAD_DIR=

# === Email SMTP ===
# Outbound email server settings (Gmail example shown)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP login (for Gmail, use the account email)
SMTP_USER=
# SMTP password (for Gmail, use an App Password — not your account password)
SMTP_PASS=
# Display name in the "From" field of outbound emails
SMTP_FROM_NAME=

# === Gmail IMAP ===
# For automatic email ingestion (reading incoming client emails)
GMAIL_CENTER_EMAIL=
# Gmail App Password for IMAP access
GMAIL_CENTER_APP_PASSWORD=

# === Google Drive ===
# Path to OAuth2 credentials JSON (download from Google Cloud Console)
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/google_drive_credentials.json
# Path to the cached OAuth2 token (auto-generated after first auth)
GOOGLE_DRIVE_TOKEN_PATH=./credentials/google_drive_token.pickle
# Root folder ID in Google Drive (the "Active Clients" folder)
GOOGLE_DRIVE_ROOT_ID=
# Tasks folder ID in Google Drive
GOOGLE_DRIVE_TASKS_ID=

# === Google Calendar ===
# Optional: defaults to ./credentials/google_client_secret.json
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google_client_secret.json
# Optional: defaults to ./credentials/
GOOGLE_CALENDAR_TOKEN_DIR=./credentials
# Optional: legacy ILC pickle token path. If set, it is imported into token_center.json once.
GOOGLE_CALENDAR_LEGACY_TOKEN_PATH=
# Sync priority for CaseHub appointments. First connected account wins.
GOOGLE_CALENDAR_DEFAULT_ACCOUNTS=center,info
# Google event write behavior. Keep "none" to avoid inviting clients automatically.
GOOGLE_CALENDAR_SEND_UPDATES=none
# Create Google Meet links for synced CaseHub appointments.
GOOGLE_CALENDAR_CREATE_MEET=false

# === MCP Client Facade ===
# Default-off internal client only. Do not expose CaseHub as an MCP server.
CASEHUB_MCP_CLIENT_ENABLED=false

# === Moskit CRM ===
# API key for bidirectional CRM sync
MOSKIT_API_KEY=
# Default responsible user ID in Moskit
MOSKIT_RESPONSIBLE_ID=
# Pipeline ID for new leads
MOSKIT_PIPELINE_ID=

# === CallHippo ===
# SMS and voice call integration
CALLHIPPO_API_KEY=
# Outbound phone number
CALLHIPPO_FROM=
# CallHippo account email
CALLHIPPO_EMAIL=
# Shared secret embedded in the inbound webhook path (Sentinela C8). CallHippo
# does not sign webhooks, so the dashboard URL must be:
#   https://<host>/casehub/callhippo/webhook/<CALLHIPPO_WEBHOOK_TOKEN>/sms
#   https://<host>/casehub/callhippo/webhook/<CALLHIPPO_WEBHOOK_TOKEN>/call
# If unset, the inbound webhooks are DISABLED (return 404) — fail closed.
CALLHIPPO_WEBHOOK_TOKEN=

# === Twilio ===
# Alternative telephony provider (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
# Auth token — ALSO used to validate inbound webhook X-Twilio-Signature (C7).
TWILIO_AUTH_TOKEN=
# Outbound SMS number (e.g., +14155551234)
TWILIO_FROM_NUMBER=
# WhatsApp sender (e.g., whatsapp:+14155551234)
TWILIO_WHATSAPP_FROM=
# Set to 1/true ONLY in local/dev to bypass inbound webhook signature checks.
# Leave EMPTY in production (fail-closed signature validation, Sentinela C7).
TWILIO_SKIP_WEBHOOK_VALIDATION=

# === Stripe ===
# Billing and payment processing
STRIPE_SECRET_KEY=
# Publishable key (safe for frontend)
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (for verifying Stripe webhook events)
STRIPE_WEBHOOK_SECRET=

# === Self-service signup (Fatia B — gated by Council ruling) ===
# Master kill switch. Keep FALSE until ruling 2026-05-24-self-service-signup
# (or successor) explicitly approves go-live.
SELF_SERVICE_SIGNUP_ENABLED=false
# Cloudflare Turnstile — captcha for the public /signup form.
# Site key is safe in the repo; secret key must be filled in by the deploy
# environment (production .env, never committed).
CF_TURNSTILE_SITE_KEY=0x4AAAAAADVoo2yqCgi5PoBB
CF_TURNSTILE_SECRET_KEY=
# Email-verification token lifetime (hours).
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
# Rate-limit caps for the public signup endpoint.
SIGNUP_RATE_LIMIT_PER_IP_PER_HOUR=5
SIGNUP_RATE_LIMIT_PER_DOMAIN_PER_DAY=3

# === Notion ===
# Notion integration for knowledge base and ticketing
NOTION_TOKEN=
# AILA Wiki database ID
NOTION_AILA_WIKI_DB=
# Ticket/support database ID
NOTION_TICKET_DATABASE_ID=

# === AI APIs ===
# Perplexity API for legal research
PERPLEXITY_API_KEY=
# Google Gemini API for document generation
GEMINI_API_KEY=
# Resend API for transactional emails
RESEND_API_KEY=

# === Brazilian Legal APIs ===
# Escavador API for processo search and monitoring
# ESCAVADOR_API_KEY=your_key_here
# JusBrasil API for process consultation and documents
# JUSBRASIL_API_KEY=your_key_here
# DataJud (CNJ) API key (free public API, optional override)
# DATAJUD_API_KEY=your_key_here

# === Alerts ===
# Phone number for SMS alerts (e.g., server errors)
ALERT_PHONE=
# WhatsApp number for alerts
ALERT_WHATSAPP=

# === CRM Webhook ===
# API key for inbound CRM webhook authentication
CRM_WEBHOOK_API_KEY=
