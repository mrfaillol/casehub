{% extends "base.html" %}
<!-- TESTE UNICO 12345 CLAUDE -->
{% block title %}Tasks - ILC CaseHub{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tasks me-2"></i>Tasks</h2>
    <a href="{{ PREFIX }}/tasks/new" class="btn btn-primary"><i class="fas fa-plus me-1"></i> New Task</a>
</div>

<!-- Task Source Tabs -->
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link" href="{{ PREFIX }}/tasks/notion">
            <i class="fab fa-notion me-1"></i> Notion Tasks (Juliana + Ana)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link active" href="{{ PREFIX }}/tasks/local">
            <i class="fas fa-database me-1"></i> Tasks Locais
        </a>
    </li>
</ul>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h3 class="mb-0">{{ overdue_count }}</h3>
                <small>Overdue</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning">
            <div class="card-body text-center">
                <h3 class="mb-0">{{ today_count }}</h3>
                <small>Due Today</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h3 class="mb-0">{{ total }}</h3>
                <small>Total Active</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <a href="{{ PREFIX }}/tasks?show_completed=true" class="text-decoration-none">
                    <i class="fas fa-check-circle text-success"></i> Show Completed
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:40px"></th>
                    <th>Task</th>
                    <th>Client/Case</th>
                    <th>Due Date</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th style="width:100px">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for task in tasks %}
                <tr class="{% if task.status == 'completed' %}text-muted{% endif %}">
                    <td class="text-center">
                        {% if task.status != 'completed' %}
                        <form method="post" action="{{ PREFIX }}/tasks/{{ task.id }}/complete" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-success" title="Mark Complete">
                                <i class="fas fa-check"></i>
                            </button>
                        </form>
                        {% else %}
                        <i class="fas fa-check-circle text-success"></i>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ PREFIX }}/tasks/{{ task.id }}" class="text-decoration-none">
                            <strong>{{ task.title }}</strong>
                        </a>
                        {% if task.task_type %}
                        <br><small class="text-muted">{{ task.task_type }}</small>
                        {% endif %}
                    </td>
                    <td>
                        {% if task.client %}
                        <a href="{{ PREFIX }}/clients/{{ task.client.id }}">{{ task.client.first_name }} {{ task.client.last_name }}</a>
                        {% endif %}
                        {% if task.case %}
                        <br><a href="{{ PREFIX }}/cases/{{ task.case.id }}" class="text-muted">{{ task.case.case_number or task.case.case_name }}</a>
                        {% endif %}
                        {% if not task.client and not task.case %}
                        <span class="text-muted">-</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if task.due_date %}
                            {% if task.due_date < now() and task.status != 'completed' %}
                                <span class="text-danger"><i class="fas fa-exclamation-circle me-1"></i>{{ task.due_date.strftime('%Y-%m-%d') }}</span>
                            {% elif task.due_date == now() %}
                                <span class="text-warning"><i class="fas fa-clock me-1"></i>Today</span>
                            {% else %}
                                {{ task.due_date.strftime('%Y-%m-%d') }}
                            {% endif %}
                        {% else %}
                            <span class="text-muted">No due date</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if task.priority == 'urgent' %}<span class="badge bg-danger">Urgent</span>
                        {% elif task.priority == 'high' %}<span class="badge bg-warning">High</span>
                        {% elif task.priority == 'medium' %}<span class="badge bg-info">Medium</span>
                        {% else %}<span class="badge bg-secondary">Low</span>{% endif %}
                    </td>
                    <td>
                        {% if task.status == 'completed' %}<span class="badge bg-success">Completed</span>
                        {% elif task.status == 'in_progress' %}<span class="badge bg-primary">In Progress</span>
                        {% elif task.status == 'blocked' %}<span class="badge bg-danger">Blocked</span>
                        {% else %}<span class="badge bg-secondary">Pending</span>{% endif %}
                    </td>
                    <td>
                        <a href="{{ PREFIX }}/tasks/{{ task.id }}/edit" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                        <form method="post" action="{{ PREFIX }}/tasks/{{ task.id }}/delete" class="d-inline" onsubmit="return confirm('Delete this task?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center py-5 text-muted">
                        <i class="fas fa-tasks fa-3x mb-3 d-block"></i>
                        No tasks found. <a href="{{ PREFIX }}/tasks/new">Create one</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if total > per_page %}
<nav class="mt-4">
    <ul class="pagination justify-content-center">
        {% for p in range(1, (total // per_page) + 2) %}
        <li class="page-item {% if p == page %}active{% endif %}">
            <a class="page-link" href="{{ PREFIX }}/tasks?page={{ p }}&status={{ status }}&priority={{ priority }}&show_completed={{ show_completed }}">{{ p }}</a>
        </li>
        {% endfor %}
    </ul>
</nav>
{% endif %}
{% endblock %}

{% block extra_js %}
<script>
function refreshTasks() {
    location.reload();
}

function switchView(view) {
    const tasksList = document.getElementById("tasksList") || document.querySelector(".table-responsive, .tasks-container");
    const listBtn = document.getElementById("view-list") || document.getElementById("view-list-btn");
    const kanbanBtn = document.getElementById("view-kanban") || document.getElementById("view-kanban-btn");
    
    if (!tasksList) {
        console.warn("Tasks list container not found");
        return;
    }
    
    if (view === "list") {
        tasksList.classList.remove("kanban-view");
        tasksList.classList.add("list-view");
        if (listBtn) listBtn.classList.add("active");
        if (kanbanBtn) kanbanBtn.classList.remove("active");
        localStorage.setItem("tasksView", "list");
    } else if (view === "kanban") {
        tasksList.classList.remove("list-view");
        tasksList.classList.add("kanban-view");
        if (kanbanBtn) kanbanBtn.classList.add("active");
        if (listBtn) listBtn.classList.remove("active");
        localStorage.setItem("tasksView", "kanban");
    }
}

// Restore view on load
document.addEventListener("DOMContentLoaded", () => {
    const savedView = localStorage.getItem("tasksView") || "list";
    if (typeof switchView === "function") {
        switchView(savedView);
    }
});
</script>
{% endblock %}
