# Uploads (may contain sensitive documents)
uploads/

# Maestro runtime artifacts (regenerable; the repo index embeds file contents
# and is large — build with scripts/maestro_index_repo.py, never commit). The
# directory is created at build time (scripts/maestro_index_repo.py) and mounted
# as a volume in docker-compose.alpha.yml, so nothing here needs to be tracked.
runtime/

# Node modules
node_modules/

# OS files
.DS_Store
._*
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Credentials (extra safety)
credentials/
*credentials*.json
*secret*.json
*.pem
*.key

# Pickle files (tokens, caches)
*.pickle

# Data files
data/vectors/

# Coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Backup files
*.bak
*.backup
*.bak.*
*.backup.*
backups/
backup_20260306/

# scripts/apply-routers-patch.sh writes core/app_factory.py.pre-cmd-activation.<ts>.bak
# (matched by *.bak above; explicit entry for compliance with audit rule)
core/*.bak

# Old rollback/backup copies
*.backup.ilctools.*
*_rollback*

# Logos (org-specific, uploaded at runtime)
static/img/logos/*
!static/img/logos/.gitkeep
audit-screenshots/
audit-issues-*.json
audit-report-*.md

# Private seed data (real client PII — never commit)
scripts/seed_vieira_salles*.py
seeds-private/

# Client data exports (SQL dumps — never commit)
data-exports/

# === audit-2026-04-28 reinforcement (see docs/audit-2026-04-28.md) ===
# Cat C — PII / work-product / sigilo advogado-cliente
client_documents/

# Cat B — operational state (snapshots, status reports, backups ad-hoc)
ORCHESTRA_STATUS.md
**/.orchestra/state.json
*.SAFE_BACKUP_*

# GitOps deploy audit markers written on VS-prod
.deploy-sha
.deploy-timestamp
.deploy-actor
.previous-sha
.bootstrap-log

# Visual regression run output (per-run; baselines committed separately)
tests/visual-audit/results/

# === Higiene alpha 2026-05-28 (PR cleanup) ===
# Output de testes visuais Playwright (gerado por run)
test-results/
playwright-report/
# Screenshots de handoff/auditoria datados
docs/handoff/**/*screenshots*/
# Relatórios de segurança gerados (bandit/pip-audit/load-test/benchmark/pytest)
security/*-report.txt
security/benchmark-*.txt
security/image.png
security/*.pdf
security/*.docx
# Outputs gerados ILC-tools (work-product + PII de clientes reais)
services/ilc-tools/output/
