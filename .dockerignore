# Version control
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache

# Virtual environments
venv
.venv
env

# IDE
.vscode
.idea
*.swp
*.swo

# Testing
tests/
htmlcov/
.coverage

# Documentation (not needed in container)
docs/
*.md
!README.md

# Backups and temp files
backups/
backup_*/
*.backup
*.bak
*.sql
*.tar.gz
*.db
.deploy-*
!.deploy-sha
.previous-sha
VERSION_COMMIT
!VERSION_COMMIT

# Uploads (mounted as volume in production)
uploads/*
!uploads/.gitkeep
client_documents/

# Logs
logs/*
!logs/.gitkeep
*.log

# Development files
benchmarks/
scripts/
pentest.py
*.py.backup
send_log_*.txt
output/

# OS files
.DS_Store
Thumbs.db

# Docker
docker-compose*.yml
Dockerfile
.dockerignore

# Node (whatsapp-bot has its own build)
node_modules/

# Credentials (should never be in image)
credentials/
*.pickle
*.p12
*.pem
.env
.env.*
!.env.example
