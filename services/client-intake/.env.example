# ===========================================
# CaseHub Client Intake Portal - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=postgresql://casehub:changeme@localhost/casehub

# --- Application ---
APP_BASE_PATH=/opt/casehub

# --- Document Uploads ---
PORTAL_UPLOAD_DIR=/tmp/portal_uploads

# --- SMTP Email Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=info@casehub.app
