# ===========================================
# CaseHub WhatsApp Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# --- Server ---
PORT=3001
NODE_ENV=development
UI_ACCESS_TOKEN=
BOT_NAME=CaseHub WhatsApp Bot
BUSINESS_PHONE=

# --- MySQL Database ---
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- PostgreSQL Database ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=casehub
PG_PASSWORD=
PG_DATABASE=casehub

# --- Gemini AI ---
GEMINI_API_KEY=

# --- Moskit CRM ---
MOSKIT_API_KEY=
MOSKIT_RESPONSIBLE_ID=105810
MOSKIT_PIPELINE_ID=70006

# --- Stripe Payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONSULTATION_PRICE=

# --- Calendly ---
CALENDLY_API_KEY=
CALENDLY_ORG_URL=
CALENDLY_USER_URL=

# --- Email (Resend + Gmail SMTP) ---
RESEND_API_KEY=
GMAIL_CENTER_EMAIL=
GMAIL_CENTER_APP_PASSWORD=

# --- CallHippo (optional) ---
CALLHIPPO_API_KEY=
CALLHIPPO_EMAIL=
CALLHIPPO_FROM=
CALLHIPPO_TO=
CALLHIPPO_WEBHOOK_SECRET=

# --- Twilio (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Facebook Pixel / CAPI (optional) ---
FB_PIXEL_ID=
FB_CAPI_TOKEN=

# --- Google Ads (optional) ---
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# --- Google Analytics 4 (optional) ---
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# --- CRM Sync (optional) ---
CRM_SYNC_ENABLED=false
CRM_WEBHOOK_URL=
CRM_WEBHOOK_API_KEY=

# --- Maestro AI (optional) ---
MAESTRO_ACTIVATION_ENABLED=false
MAESTRO_ADMIN_PHONE=
MAESTRO_API_KEY=
MAESTRO_URL=
PERPLEXITY_API_KEY=

# --- Notifications (optional) ---
GOOGLE_CHAT_WEBHOOK_ADMIN=
